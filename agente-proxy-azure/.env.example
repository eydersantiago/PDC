# Modo de ejecucion: local | azure
AGENT_TARGET=local

# Puerto del proxy
PORT=3000

# CORS (opcional): lista separada por comas
# ALLOWED_ORIGINS=http://localhost:5173,https://tu-frontend.com
# Si queda vacia, el servidor permite cualquier origen (util para extension local).

# Limite de caracteres para el contenido de pestana enviado al agente
MAX_TAB_CONTENT_CHARS=12000
# Limite de codigo para endpoint /github-mentor
MAX_MENTOR_CODE_CHARS=6000

# -------- Local --------
OPENAI_BASE=http://127.0.0.1:11434/v1
OPENAI_API_KEY=dummy
MODEL_TEXT=qwen2.5:7b-instruct

OLLAMA_URL=http://127.0.0.1:11434
MODEL_VISION=qwen2.5vl:7b-gpu

# -------- Azure --------
# URL base del servidor remoto (sin slash final), por ejemplo:
# AZURE_SERVER_URL=https://mi-agente.azurewebsites.net
AZURE_SERVER_URL=
