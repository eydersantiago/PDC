# Modo de ejecucion: local | azure
AGENT_TARGET=local

# Puerto del proxy
PORT=3000

# CORS (opcional): lista separada por comas
# ALLOWED_ORIGINS=http://localhost:5173,https://tu-frontend.com
# Si queda vacia, el servidor permite cualquier origen (util para extension local).

# Limite de caracteres para el contenido de pestana enviado al agente
MAX_TAB_CONTENT_CHARS=12000
# Limite de codigo para endpoint /github-mentor
MAX_MENTOR_CODE_CHARS=6000

# -------- Local --------
OPENAI_BASE=http://127.0.0.1:11434/v1
OPENAI_API_KEY=dummy
MODEL_TEXT=qwen2.5:7b-instruct

OLLAMA_URL=http://127.0.0.1:11434
MODEL_VISION=qwen2.5vl:7b-gpu

# -------- Azure --------
# URL base del servidor remoto (sin slash final), por ejemplo:
# AZURE_SERVER_URL=https://mi-agente.azurewebsites.net
AZURE_SERVER_URL=

# -------- Base de datos --------
# Si DATABASE_URL queda vacia, el backend usa una base PostgreSQL en memoria
# con usuarios demo y politicas seed para el piloto.
# Para Azure, apunta este valor al servidor de PostgreSQL Flexible Server.
DATABASE_URL=
# disable | require
DATABASE_SSL_MODE=disable

# -------- GitHub App (opcion estable) --------
# Id numerico de la GitHub App
GITHUB_APP_ID=
# Slug de la app (ejemplo: adaceen-bootstrap)
GITHUB_APP_SLUG=
# Llave privada PEM de la app (puede pegarse con saltos o con \n)
GITHUB_APP_PRIVATE_KEY=
# Setup URL configurado en la app, por ejemplo:
# http://127.0.0.1:3000/api/github-app/callback
GITHUB_APP_SETUP_URL=
# API base de GitHub (normalmente no cambiar)
GITHUB_API_BASE_URL=https://api.github.com
